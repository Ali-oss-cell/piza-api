# Production (Droplet + Managed PostgreSQL + Traefik)
# Copy to .env in piza-api before: docker compose -f docker-compose.prod.yml up -d --build

# --- Traefik / domains ---
ACME_EMAIL=you@marinapizzas.com.au
API_DOMAIN=api.marinapizzas.com.au
WEB_DOMAIN=marinapizzas.com.au
WEB_WWW_DOMAIN=www.marinapizzas.com.au

# Path to piza-front clone (sibling of piza-api on the droplet)
FRONTEND_DIR=../piza-front
NEXT_PUBLIC_API_URL=https://api.marinapizzas.com.au/api

# --- API ---
NODE_ENV=production
PORT=3001
API_PREFIX=api
CORS_ORIGIN=https://marinapizzas.com.au,https://www.marinapizzas.com.au

# DigitalOcean Managed PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/marinapizzas?sslmode=require

JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=1d

ADMIN_SEED_EMAIL=admin@leovorno.com
ADMIN_SEED_PASSWORD=ChangeMe!2026
ADMIN_SEED_FIRST_NAME=Marina
ADMIN_SEED_LAST_NAME=Admin

# First deploy only: set RUN_SEED=true once, then false forever
RUN_MIGRATIONS=true
RUN_SEED=true
