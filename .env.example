# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://leovorno:leovorno_secret@localhost:5432/leovorno?schema=public

# JWT Authentication
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=1d

# Initial Admin Seed (idempotent — only created if email does not exist)
ADMIN_SEED_EMAIL=admin@leovorno.com
ADMIN_SEED_PASSWORD=ChangeMe!2026
ADMIN_SEED_FIRST_NAME=Leovorno
ADMIN_SEED_LAST_NAME=Admin

# Bootstrap controls (Docker entrypoint uses these)
RUN_MIGRATIONS=true
RUN_SEED=true
